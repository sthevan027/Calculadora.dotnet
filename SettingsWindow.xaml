<Window x:Class="Calculadora.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações"
        Icon="{DynamicResource AppIcon}"
        Width="448"
        MinHeight="360"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        Background="{DynamicResource App.Bg}">
    <Grid Margin="18">
        <Border CornerRadius="18"
                Background="{DynamicResource App.Card}"
                BorderBrush="{DynamicResource App.Border}"
                BorderThickness="1"
                ClipToBounds="False"
                Effect="{DynamicResource App.Shadow}">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Configurações" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource App.Text}" />
                        <TextBlock Text="Preferências do aplicativo" Margin="0,4,0,0" Foreground="{DynamicResource App.Muted}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="38"
                            Height="38"
                            CornerRadius="14"
                            Background="{DynamicResource App.Card2}"
                            BorderBrush="{DynamicResource App.Border}"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <TextBlock Text="⚙" FontSize="16" Foreground="{DynamicResource App.Muted}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <TabControl Grid.Row="1"
                            Margin="0,16,0,0"
                            VerticalAlignment="Top"
                            Style="{DynamicResource Calc.TabControl}">
                    <TabItem Header="Geral" Style="{DynamicResource Calc.TabItem}">
                        <StackPanel Margin="0,14,0,0">
                            <Border CornerRadius="16"
                                    Background="{DynamicResource App.Card2}"
                                    BorderBrush="{DynamicResource App.Border}"
                                    BorderThickness="1">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tema" Foreground="{DynamicResource App.Muted}" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ThemeCombo"
                                              Grid.Row="1"
                                              Margin="0,10,0,0"
                                              SelectionChanged="ThemeCombo_SelectionChanged"
                                              Style="{DynamicResource Calc.ComboBox}">
                                        <ComboBoxItem Content="Sistema" Tag="System" />
                                        <ComboBoxItem Content="Claro" Tag="Light" />
                                        <ComboBoxItem Content="Escuro" Tag="Dark" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    CornerRadius="16"
                                    Background="{DynamicResource App.Card2}"
                                    BorderBrush="{DynamicResource App.Border}"
                                    BorderThickness="1">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Modo da Calculadora" Foreground="{DynamicResource App.Muted}" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ModeCombo"
                                              Grid.Row="1"
                                              Margin="0,10,0,0"
                                              SelectionChanged="ModeCombo_SelectionChanged"
                                              Style="{DynamicResource Calc.ComboBox}">
                                        <ComboBoxItem Content="Básica" Tag="Basic" />
                                        <ComboBoxItem Content="Científica" Tag="Scientific" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    CornerRadius="16"
                                    Background="{DynamicResource App.Card2}"
                                    BorderBrush="{DynamicResource App.Border}"
                                    BorderThickness="1">
                                <Grid Margin="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Histórico" Foreground="{DynamicResource App.Muted}" FontWeight="SemiBold" />
                                        <TextBlock Text="Mostrar painel de histórico na calculadora"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource App.Muted}" />
                                    </StackPanel>
                                    <CheckBox x:Name="HistoryCheck"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{DynamicResource Calc.Switch}"
                                              IsChecked="True"
                                              Checked="HistoryCheck_Changed"
                                              Unchecked="HistoryCheck_Changed" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Científica" Style="{DynamicResource Calc.TabItem}">
                        <StackPanel Margin="0,14,0,0">
                            <Border CornerRadius="16"
                                    Background="{DynamicResource App.Card2}"
                                    BorderBrush="{DynamicResource App.Border}"
                                    BorderThickness="1">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Ângulo" Foreground="{DynamicResource App.Muted}" FontWeight="SemiBold" />
                                    <ComboBox x:Name="AngleCombo"
                                              Grid.Row="1"
                                              Margin="0,10,0,0"
                                              SelectionChanged="AngleCombo_SelectionChanged"
                                              Style="{DynamicResource Calc.ComboBox}">
                                        <ComboBoxItem Content="Graus" Tag="Degrees" />
                                        <ComboBoxItem Content="Radianos" Tag="Radians" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource App.Muted}"
                                       TextWrapping="Wrap"
                                       Text="Esta opção afeta sin/cos/tan (entrada) e asin/acos/atan (saída) no modo Científica." />
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,4">
                    <Button Content="Fechar" Width="120" Click="Close_Click" Style="{DynamicResource Calc.Button}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

