<Window x:Class="Calculadora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculadora"
        mc:Ignorable="d"
        Title="Calculadora"
        Icon="{DynamicResource AppIcon}"
        Width="420"
        Height="680"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource App.Bg}"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Grid Margin="14">
        <Border CornerRadius="22"
                BorderThickness="1"
                BorderBrush="{DynamicResource App.Border}">
            <Border.Background>
                <DynamicResource ResourceKey="App.Card" />
            </Border.Background>
            <Border.Effect>
                <DynamicResource ResourceKey="App.Shadow" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="128" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0" Opacity="0.95">
                        <TextBlock Text="Calculadora" Foreground="{DynamicResource App.Text}" FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" />
                        <TextBlock Text=" ·" Foreground="{DynamicResource App.Muted}" Margin="6,0,0,0" />
                        <TextBlock x:Name="ModeBadge" Text="Básica" Foreground="{DynamicResource App.Muted}" Margin="4,0,0,0" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="36"
                            Height="30"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource App.Card2}"
                            BorderBrush="{DynamicResource App.Border}"
                            Foreground="{DynamicResource App.Muted}"
                            Click="Settings_Click"
                            Content="⚙"
                            FontSize="14"
                            FontWeight="Bold"
                            Style="{DynamicResource Calc.Button}" />

                    <Button Grid.Column="2"
                            Width="36"
                            Height="30"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource App.Card2}"
                            BorderBrush="{DynamicResource App.Border}"
                            Foreground="{DynamicResource App.Muted}"
                            Click="Minimize_Click"
                            Content="—"
                            FontSize="14"
                            FontWeight="Bold"
                            Style="{DynamicResource Calc.Button}" />

                    <Button Grid.Column="3"
                            Width="36"
                            Height="30"
                            Margin="0,0,14,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource App.Card2}"
                            BorderBrush="{DynamicResource App.Border}"
                            Foreground="{DynamicResource App.Text}"
                            Click="Close_Click"
                            Content="×"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{DynamicResource Calc.Button}" />
                </Grid>

                <!-- Display -->
                <Grid Grid.Row="1" Margin="18,8,18,10">
                    <Border CornerRadius="18"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource App.Border}"
                            Background="{DynamicResource App.Bg}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.18" Color="#000000" />
                        </Border.Effect>
                    </Border>

                    <Grid Margin="16,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ExpressionText"
                                   Grid.Row="0"
                                   Text=""
                                   Foreground="{DynamicResource App.Muted}"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock x:Name="DisplayText"
                                   Grid.Row="1"
                                   Text="0"
                                   Foreground="{DynamicResource App.Text}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="46"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>

                <!-- Keypad -->
                <Grid Grid.Row="2" Margin="18,0,18,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Main keypad -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Scientific rows -->
                        <UniformGrid x:Name="ScientificRow1" Grid.Row="0" Columns="5" Rows="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <Button Content="(" Click="Paren_Click" Tag="(" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content=")" Click="Paren_Click" Tag=")" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="π" Click="Const_Click" Tag="pi" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="e" Click="Const_Click" Tag="e" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="^" Click="Op_Click" Tag="^" Style="{DynamicResource Calc.ButtonOpKey}" />
                        </UniformGrid>

                        <UniformGrid x:Name="ScientificRow2" Grid.Row="1" Columns="5" Rows="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <Button Content="sin" Click="Func_Click" Tag="sin" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="cos" Click="Func_Click" Tag="cos" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="tan" Click="Func_Click" Tag="tan" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="log" Click="Func_Click" Tag="log" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="√" Click="Func_Click" Tag="sqrt" Style="{DynamicResource Calc.ButtonOpKey}" />
                        </UniformGrid>

                        <UniformGrid x:Name="ScientificRow3" Grid.Row="2" Columns="5" Rows="1" Margin="0,0,0,12" Visibility="Collapsed">
                            <Button Content="ln" Click="Func_Click" Tag="ln" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="abs" Click="Func_Click" Tag="abs" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="exp" Click="Func_Click" Tag="exp" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="asin" Click="Func_Click" Tag="asin" Style="{DynamicResource Calc.ButtonOpKey}" />
                            <Button Content="acos" Click="Func_Click" Tag="acos" Style="{DynamicResource Calc.ButtonOpKey}" />
                        </UniformGrid>

                        <UniformGrid Grid.Row="3" Columns="4" Rows="1" Margin="0,0,0,12">
                            <Button Content="C" Click="Clear_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="⌫" Click="Backspace_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="%" Click="Percent_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Content="÷" Click="Op_Click" Tag="/" Style="{DynamicResource Calc.ButtonOpKey}" />
                        </UniformGrid>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <!-- Row 1 -->
                            <Button Grid.Row="0" Grid.Column="0" Content="7" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="0" Grid.Column="1" Content="8" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="0" Grid.Column="2" Content="9" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="0" Grid.Column="3" Content="×" Click="Op_Click" Tag="*" Style="{DynamicResource Calc.ButtonOpKey}" />

                            <!-- Row 2 -->
                            <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="1" Grid.Column="3" Content="−" Click="Op_Click" Tag="-" Style="{DynamicResource Calc.ButtonOpKey}" />

                            <!-- Row 3 -->
                            <Button Grid.Row="2" Grid.Column="0" Content="1" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="2" Grid.Column="1" Content="2" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="2" Grid.Column="2" Content="3" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="2" Grid.Column="3" Content="+" Click="Op_Click" Tag="+" Style="{DynamicResource Calc.ButtonOpKey}" />

                            <!-- Row 4 -->
                            <Button Grid.Row="3" Grid.Column="0" Content="±" Click="PlusMinus_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="3" Grid.Column="1" Content="0" Click="Digit_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="3" Grid.Column="2" Content="," Click="Decimal_Click" Style="{DynamicResource Calc.ButtonKey}" />
                            <Button Grid.Row="3" Grid.Column="3" Content="=" Click="Equals_Click" Style="{DynamicResource Calc.ButtonPrimaryKey}" />
                        </Grid>
                    </Grid>

                    <!-- History -->
                    <Border x:Name="HistoryPanel"
                            Grid.Column="1"
                            Width="190"
                            CornerRadius="18"
                            Background="{DynamicResource App.Card2}"
                            BorderBrush="{DynamicResource App.Border}"
                            BorderThickness="0"
                            Visibility="Collapsed">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Histórico" Foreground="{DynamicResource App.Muted}" FontWeight="SemiBold" />
                                <Button Grid.Column="1" Content="Limpar" Click="ClearHistory_Click" Padding="10,6" Style="{DynamicResource Calc.Button}" />
                            </Grid>

                            <ListBox x:Name="HistoryList"
                                     Grid.Row="1"
                                     Margin="0,10,0,10"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="HistoryList_SelectionChanged" />

                            <TextBlock Grid.Row="2"
                                       Text="Clique em um item para reutilizar"
                                       Foreground="{DynamicResource App.Muted}"
                                       FontSize="11" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
